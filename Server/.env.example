# Environment
NODE_ENV=development
PORT=3000

# Database (MySQL)
DATABASE_URL="mysql://user:password@localhost:3306/zcore"

# Admin — used to call POST /api/platforms/register
# Generate a strong random string for production
ADMIN_SECRET="change_me_in_production"

# Stellar Network: "mainnet" (default) or "testnet"
STELLAR_NETWORK=mainnet

# Soroban Score Registry (optional — enables on-chain attestation)
# SCORE_REGISTRY_CONTRACT_ID=C...
# ORACLE_SECRET_KEY=S...
# SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
