# =============================================================================
# ZCore API — local development
# Copy this file to .env:  copy .env.example .env
# =============================================================================

NODE_ENV=development
PORT=3000

# MySQL — matches docker-compose.yml defaults (docker compose up -d)
DATABASE_URL="mysql://root:zcore_dev@localhost:3306/zcore"

# Admin key for POST /api/platforms/register
ADMIN_SECRET="dev_admin_secret_local"

# Stellar network: use testnet for local dev
STELLAR_NETWORK=testnet

# CORS — comma-separated browser origins allowed to call the API
CORS_ORIGINS="http://localhost:3001,http://127.0.0.1:3001"

# Horizon wallet data cache (15 min default)
HORIZON_CACHE_ENABLED=true
HORIZON_CACHE_TTL_MS=900000

# -----------------------------------------------------------------------------
# Optional — Soroban on-chain score attestation
# Deploy Contracts/score-registry first, then uncomment:
# SCORE_REGISTRY_CONTRACT_ID=C...
# ORACLE_SECRET_KEY=S...
# SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
